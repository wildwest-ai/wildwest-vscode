{
  "name": "wildwest-vscode",
  "displayName": "Wild West",
  "description": "Wild West governance framework for VSCode — heartbeat, telegraph, dyad session activity log",
  "repository": {
    "type": "git",
    "url": "https://github.com/wildwest-ai/wildwest-vscode.git"
  },
  "version": "0.31.38",
  "publisher": "wildwest-ai",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wildwest.startWatcher",
        "title": "Start Watcher",
        "category": "Wild West"
      },
      {
        "command": "wildwest.stopWatcher",
        "title": "Stop Watcher",
        "category": "Wild West"
      },
      {
        "command": "wildwest.exportNow",
        "title": "Export Dyad Log Now",
        "category": "Wild West"
      },
      {
        "command": "wildwest.rebuildIndex",
        "title": "Rebuild Session Index",
        "category": "Wild West"
      },
      {
        "command": "wildwest.toggleSessionSortBy",
        "title": "Toggle Session Sort (Created / Updated)",
        "category": "Wild West"
      },
      {
        "command": "wildwest.batchConvert",
        "title": "Batch Convert All Sessions",
        "category": "Wild West"
      },
      {
        "command": "wildwest.convertToMarkdown",
        "title": "Convert Exports to Markdown",
        "category": "Wild West"
      },
      {
        "command": "wildwest.generateIndex",
        "title": "Generate Index",
        "category": "Wild West"
      },
      {
        "command": "wildwest.startHeartbeat",
        "title": "Start Heartbeat",
        "category": "Wild West"
      },
      {
        "command": "wildwest.stopHeartbeat",
        "title": "Stop Heartbeat",
        "category": "Wild West"
      },
      {
        "command": "wildwest.restartAdapter",
        "title": "Restart AI Tool Adapter",
        "category": "Wild West"
      },
      {
        "command": "wildwest.viewTelegraph",
        "title": "View Telegraph",
        "category": "Wild West"
      },
      {
        "command": "wildwest.soloModeReport",
        "title": "Solo Mode Report",
        "category": "Wild West"
      },
      {
        "command": "wildwest.initTown",
        "title": "Init Town",
        "category": "Wild West"
      },
      {
        "command": "wildwest.initCounty",
        "title": "Init County",
        "category": "Wild West"
      },
      {
        "command": "wildwest.initTerritory",
        "title": "Init Territory",
        "category": "Wild West"
      },
      {
        "command": "wildwest.processInbox",
        "title": "Process Inbox (rule 23)",
        "category": "Wild West"
      },
      {
        "command": "wildwest.menu",
        "title": "Menu",
        "category": "Wild West"
      },
      {
        "command": "wildwest.showStatus",
        "title": "Show Status",
        "category": "Wild West"
      },
      {
        "command": "wildwest.resetSessionConsent",
        "title": "Reset Session Export Consent",
        "category": "Wild West"
      },
      {
        "command": "wildwest.validateRegistry",
        "title": "Validate Registry",
        "category": "Wild West"
      },
      {
        "command": "wildwest.doctor",
        "title": "Doctor",
        "category": "Wild West"
      },
      {
        "command": "wildwest.openExportFolder",
        "title": "Open Export Folder",
        "category": "Wild West"
      },
      {
        "command": "wildwest.viewOutputLog",
        "title": "View Output Log",
        "category": "Wild West"
      },
      {
        "command": "wildwest.openSettings",
        "title": "Open Settings",
        "category": "Wild West"
      },
      {
        "command": "wildwest.setIdentity",
        "title": "Set Identity",
        "category": "Wild West"
      },
      {
        "command": "wildwest.telegraphAck",
        "title": "Ack Telegraph Memo",
        "category": "Wild West"
      },
      {
        "command": "wildwest.telegraphSend",
        "title": "Send Telegraph Memo",
        "category": "Wild West"
      },
      {
        "command": "wildwest.refreshSidePanel",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Wild West"
      },
      {
        "command": "wildwest.showReceipts",
        "title": "Delivery Receipts",
        "category": "Wild West"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wildwest-panel",
          "title": "Wild West",
          "icon": "media/wildwest-icon.svg"
        }
      ]
    },
    "views": {
      "wildwest-panel": [
        {
          "id": "wildwest.sidepanel",
          "name": "Wild West"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "wildwest.refreshSidePanel",
          "when": "view == wildwest.sidepanel",
          "group": "navigation"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "wildwest.participant",
        "name": "wildwest",
        "fullName": "Wild West",
        "description": "Query Wild West governance state — telegraph inbox, board branches, town status",
        "isSticky": false
      }
    ],
    "configuration": {
      "title": "Wild West",
      "properties": {
        "wildwest.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Wild West framework on startup"
        },
        "wildwest.exportPath": {
          "type": "string",
          "default": "",
          "description": "Path where dyad session logs should be saved. Leave empty to use default: ~/wildwest-logs/{git-username}/. Supports ${userHome} and ~ expansion."
        },
        "wildwest.watchInterval": {
          "type": "number",
          "default": 5000,
          "description": "File watch interval in milliseconds"
        },
        "wildwest.autoExportOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Automatically export dyad session log when chat data changes"
        },
        "wildwest.heartbeat.town.intervalMs": {
          "type": "number",
          "default": 300000,
          "description": "Town heartbeat idle interval in ms (default: 300000 = 5 min). Overridden by registry.json heartbeat.interval_ms."
        },
        "wildwest.heartbeat.town.intervalActiveMs": {
          "type": "number",
          "default": 120000,
          "description": "Town heartbeat active interval in ms when active_branches > 0 (default: 120000 = 2 min). Overridden by registry.json heartbeat.interval_active_ms."
        },
        "wildwest.heartbeat.county.intervalMs": {
          "type": "number",
          "default": 1800000,
          "description": "County heartbeat idle interval in ms (default: 1800000 = 30 min). Overridden by registry.json heartbeat.interval_ms."
        },
        "wildwest.heartbeat.county.intervalActiveMs": {
          "type": "number",
          "default": 900000,
          "description": "County heartbeat active interval in ms when active_branches > 0 (default: 900000 = 15 min). Overridden by registry.json heartbeat.interval_active_ms."
        },
        "wildwest.heartbeat.world.intervalMs": {
          "type": "number",
          "default": 3600000,
          "description": "World heartbeat idle interval in ms (default: 3600000 = 1 hr). Overridden by registry.json heartbeat.interval_ms."
        },
        "wildwest.heartbeat.world.intervalActiveMs": {
          "type": "number",
          "default": 1800000,
          "description": "World heartbeat active interval in ms when active_branches > 0 (default: 1800000 = 30 min). Overridden by registry.json heartbeat.interval_active_ms."
        },
        "wildwest.claudeCode.hookPort": {
          "type": "number",
          "default": 7379,
          "description": "Local HTTP port for Claude Code hook receiver (ClaudeCodeAdapter). Default: 7379. Change if port conflicts occur on shared workstations."
        },
        "wildwest.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the wwMCP server (read-only MCP server over stdio). Default: false. Must be explicitly enabled by the identity."
        },
        "wildwest.privacy.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable privacy mode: redact secrets, tokens, and absolute paths from session content before writing to staged export packets. Default: false."
        },
        "wildwest.worldRoot": {
          "type": "string",
          "default": "~/wildwest",
          "description": "Absolute path to the wwTerritory root directory. Default: ~/wildwest."
        },
        "wildwest.countiesDir": {
          "type": "string",
          "default": "counties",
          "description": "Directory name for counties, relative to worldRoot. Default: counties."
        },
        "wildwest.sessionsDir": {
          "type": "string",
          "default": "sessions",
          "description": "Directory name for session exports, relative to worldRoot. Default: sessions."
        },
        "wildwest.identity": {
          "type": "string",
          "default": "",
          "description": "Declare this window's identity (e.g., TM(RHk), CD(RSn)). Format: Role(dyad). Scope determines valid roles. Leave empty for no identity."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "package": "npx vsce package --no-dependencies --out build/",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:fsevents --format=cjs --platform=node --target=node18",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest",
    "release": "scripts/release.sh"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.x",
    "eslint": "^8.x",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.x"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^3.5.3"
  }
}
